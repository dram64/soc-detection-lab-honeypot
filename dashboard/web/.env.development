# In dev, leave VITE_API_BASE_URL empty so the API client uses relative
# /api/* paths that Vite's dev-server proxy forwards to the real API
# (configured in vite.config.ts). This avoids the CORS allowlist issue
# during local development.
#
# In production builds, set VITE_API_BASE_URL to the public API origin.
VITE_API_BASE_URL=
