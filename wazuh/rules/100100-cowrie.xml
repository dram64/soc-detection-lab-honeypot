<!--
  Wazuh rules for Cowrie SSH/Telnet honeypot events
  Rule IDs in 100100-100199 range (custom user range starts at 100000)
-->

<group name="cowrie,honeypot,">

  <!-- Base rule: any Cowrie event -->
  <rule id="100100" level="3">
    <decoded_as>cowrie-json</decoded_as>
    <description>Cowrie honeypot event</description>
  </rule>

  <!-- Failed login attempt -->
  <rule id="100101" level="5">
    <if_sid>100100</if_sid>
    <field name="eventid">cowrie.login.failed</field>
    <description>Cowrie: Failed SSH login attempt from $(src_ip) — user: $(username)</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
  </rule>

  <!-- Successful login (rare; usually means the attacker found a credential) -->
  <rule id="100102" level="10">
    <if_sid>100100</if_sid>
    <field name="eventid">cowrie.login.success</field>
    <description>Cowrie: SUCCESSFUL SSH login on honeypot from $(src_ip) — user: $(username) — INVESTIGATE</description>
    <mitre>
      <id>T1078</id>
    </mitre>
  </rule>

  <!-- Command execution after login -->
  <rule id="100103" level="8">
    <if_sid>100100</if_sid>
    <field name="eventid">cowrie.command.input</field>
    <description>Cowrie: Command executed by attacker — $(input)</description>
    <mitre>
      <id>T1059</id>
    </mitre>
  </rule>

  <!-- File download attempt -->
  <rule id="100104" level="10">
    <if_sid>100100</if_sid>
    <field name="eventid">cowrie.session.file_download</field>
    <description>Cowrie: Malware/payload download attempt — $(url)</description>
    <mitre>
      <id>T1105</id>
    </mitre>
  </rule>

  <!-- Brute force detection: 5+ failed logins from same IP in 5 min -->
  <rule id="100105" level="10" frequency="5" timeframe="300">
    <if_matched_sid>100101</if_matched_sid>
    <same_source_ip />
    <description>Cowrie: SSH brute force attack from $(src_ip) — 5+ failed attempts in 5min</description>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>

  <!-- Credential stuffing: 10+ unique usernames from same IP in 10 min -->
  <rule id="100106" level="12" frequency="10" timeframe="600">
    <if_matched_sid>100101</if_matched_sid>
    <same_source_ip />
    <different_field>username</different_field>
    <description>Cowrie: Credential stuffing from $(src_ip) — 10+ unique usernames in 10min</description>
    <mitre>
      <id>T1110.004</id>
    </mitre>
  </rule>

</group>
