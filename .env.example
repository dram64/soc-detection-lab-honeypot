# SOC Detection Lab — environment defaults
# Copy this file to .env and change every password before deploying.
# .env is gitignored and never committed.

# ============================================================
# Wazuh
# ============================================================
WAZUH_INDEXER_PASSWORD=ChangeMe_StrongPassword_1
WAZUH_API_PASSWORD=ChangeMe_StrongPassword_2

# ============================================================
# Elastic Stack
# ============================================================
ELASTIC_PASSWORD=ChangeMe_StrongPassword_3
KIBANA_PASSWORD=ChangeMe_StrongPassword_4

# ============================================================
# Splunk
# ============================================================
SPLUNK_PASSWORD=ChangeMe_StrongPassword_5

# ============================================================
# MISP
# ============================================================
MISP_ADMIN_PASSWORD=ChangeMe_StrongPassword_6
MISP_DB_PASSWORD=ChangeMe_StrongPassword_7
MISP_DB_ROOT_PASSWORD=ChangeMe_StrongPassword_8
MISP_API_KEY=  # Generate after first login via MISP UI

# ============================================================
# Honeypot (Pi 5)
# ============================================================
HONEYPOT_HOSTNAME=soc-honeypot-1
CLOUDFLARE_TUNNEL_TOKEN=  # Generated when you set up the tunnel
