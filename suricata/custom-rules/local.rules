# SOC Detection Lab — Custom Suricata rules
# These supplement the ET Open ruleset with lab-specific detections.
# Rule SIDs in the 1000000+ range to avoid conflicts with ET Open.

# ============================================================
# SSH brute force from external sources
# ============================================================
alert ssh any any -> $HOME_NET 22 ( \
  msg:"SOC LAB: SSH connection from external source"; \
  flow:to_server,established; \
  threshold: type both, track by_src, count 5, seconds 60; \
  classtype:attempted-recon; \
  sid:1000001; rev:1; \
  metadata: mitre_tactic Initial-Access, mitre_technique T1110;)

# ============================================================
# Honeypot port (2222) connection attempts — informational
# ============================================================
alert tcp $EXTERNAL_NET any -> $HOME_NET 2222 ( \
  msg:"SOC LAB: Honeypot SSH port connection attempt"; \
  flow:to_server,established; \
  classtype:not-suspicious; \
  sid:1000002; rev:1; \
  metadata: lab_signal honeypot_hit;)

# ============================================================
# Telnet honeypot connections — even more suspicious (port 23 generally unused now)
# ============================================================
alert tcp $EXTERNAL_NET any -> $HOME_NET 23 ( \
  msg:"SOC LAB: Telnet connection attempt — likely scanner/IoT-targeted"; \
  flow:to_server,established; \
  classtype:attempted-recon; \
  sid:1000003; rev:1; \
  metadata: mitre_tactic Initial-Access, mitre_technique T1110;)

# ============================================================
# Outbound to known C2 ports
# ============================================================
alert tcp $HOME_NET any -> $EXTERNAL_NET [4444,8888,9001,31337,1337,6667] ( \
  msg:"SOC LAB: Outbound connection to suspicious C2 port"; \
  flow:to_server,established; \
  classtype:trojan-activity; \
  sid:1000010; rev:1; \
  metadata: mitre_tactic Command-and-Control, mitre_technique T1571;)

# ============================================================
# DNS query to known DGA / fast-flux patterns (rough heuristic)
# ============================================================
alert dns $HOME_NET any -> any 53 ( \
  msg:"SOC LAB: DNS query for unusually long random-looking domain (possible DGA)"; \
  dns_query; \
  pcre:"/^[a-z0-9]{20,}\.[a-z]{2,4}$/i"; \
  classtype:trojan-activity; \
  sid:1000020; rev:1; \
  metadata: mitre_tactic Command-and-Control, mitre_technique T1568.002;)

# ============================================================
# Large outbound data transfer (possible exfil)
# ============================================================
alert tcp $HOME_NET any -> $EXTERNAL_NET any ( \
  msg:"SOC LAB: Unusually large outbound transfer (possible exfiltration)"; \
  flow:to_server,established; \
  flowbits:set,large_transfer; \
  byte_test:4,>,10485760,0,relative; \
  classtype:policy-violation; \
  sid:1000030; rev:1; \
  metadata: mitre_tactic Exfiltration, mitre_technique T1041;)
